generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum BoardApprovalStatus {
  PENDING
  APPROVED
}

enum BoardTag {
  BUSINESS_DEVELOPMENT
  SALES
  PRODUCT_DEVELOPMENT
  ADMINISTRATION
  CUSTOMER_SUCCESS
  MARKETING
  FINANCE
  RESEARCH
  OPERATIONS
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_SUBMITTED
  TASK_APPROVED
  TASK_REJECTED
  TASK_COMMENTED
  BOARD_APPROVED
  BOARD_REJECTED
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  emailVerified DateTime?
  name          String?
  image         String?
  isOwner       Boolean    @default(false)
  allowedTags   BoardTag[] @default([])
  createdAt     DateTime   @default(now())

  createdTasks  Task[]         @relation("CreatedTasks")
  assignedTasks Task[]         @relation("AssignedTasks")
  comments      TaskComment[]  @relation("AuthoredComments")
  notifications Notification[]

  accounts      Account[]
  sessions      Session[]
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  credits     Int
  status      TaskStatus @default(TODO)
  tag         BoardTag?
  approvalStatus BoardApprovalStatus @default(APPROVED)

  // boardId points at the root task of the lineage (a root task's boardId == its own id)
  boardId     String
  board       Task?      @relation("BoardTasks", fields: [boardId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  boardTasks  Task[]     @relation("BoardTasks")

  parentId    String?
  parent      Task?      @relation("TaskLineage", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children    Task[]     @relation("TaskLineage")

  createdById   String
  createdBy     User     @relation("CreatedTasks", fields: [createdById], references: [id])

  assignedToId  String?
  assignedTo    User?    @relation("AssignedTasks", fields: [assignedToId], references: [id])

  createdAt   DateTime   @default(now())
  assignedAt  DateTime?
  submittedAt DateTime?
  completedAt DateTime?

  comments      TaskComment[]
  notifications Notification[]

  @@index([boardId])
  @@index([parentId])
  @@index([status])
}

model TaskComment {
  id        String   @id @default(cuid())
  content   String
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("AuthoredComments", fields: [authorId], references: [id])
  createdAt DateTime @default(now())

  @@index([taskId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  taskId    String?
  task      Task?            @relation(fields: [taskId], references: [id], onDelete: SetNull)
  message   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([userId, read])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}
