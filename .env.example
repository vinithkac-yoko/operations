# Local dev: run a local Postgres (e.g. `docker run -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres:16`).
# On Railway: this is provided automatically when you add a Postgres plugin - reference it as ${{Postgres.DATABASE_URL}}.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/opsboard"

# Google OAuth (Google Workspace SSO) - https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_SECRET=""

# Comma-separated list of email addresses allowed to sign in (your company directory).
# Leave empty during local dev to allow anyone.
ALLOWED_EMAIL_DOMAIN=""

# The email of the owner account - only this user can create root/board tasks.
OWNER_EMAIL=""
